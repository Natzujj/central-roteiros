{
  "name": "central-roteiros",
  "version": "1.0.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --clean"
  },
  "build": {
    "appId": "com.central.roteiros",
    "publish": [
      {
        "provider": "github",
        "owner": "Natzujj",
        "repo": "central-roteiros"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/tutorial-icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/tutorial-icon.png"
    },
    "files": [
      "**/*",
      "!node_modules/*",
      "node_modules/better-sqlite3/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "marked": "^18.0.5",
    "multer": "^2.2.0",
    "pdf-parse-fork": "^1.2.0"
  }
}
